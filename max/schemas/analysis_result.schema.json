{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slice-labeler.local/schemas/analysis_result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "type", "requestId", "backend", "predictions", "sourceErrors"],
  "properties": {
    "schemaVersion": {"const": 1},
    "type": {"const": "result"},
    "requestId": {"type": "string", "minLength": 1},
    "backend": {"type": "object"},
    "predictions": {"type": "array", "items": {"$ref": "#/$defs/prediction"}},
    "sourceErrors": {"type": "array"}
  },
  "$defs": {
    "prediction": {
      "type": "object",
      "required": ["regionId", "classes", "scores", "matchedEvents", "decision", "topScore", "warnings"],
      "properties": {
        "regionId": {"type": "string"},
        "classes": {"type": "array", "items": {"enum": ["kick", "snare", "tom", "hihat", "cymbal", "unknown"]}},
        "scores": {"type": "object"},
        "matchedEvents": {"type": "array"},
        "decision": {"enum": ["matched_event", "activation_fallback", "unknown", "analysis_error"]},
        "topScore": {"type": "number"},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
