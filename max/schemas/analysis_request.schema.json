{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slice-labeler.local/schemas/analysis_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "type", "requestId", "method", "params"],
  "properties": {
    "schemaVersion": {"const": 1},
    "type": {"const": "request"},
    "requestId": {"type": "string", "minLength": 1},
    "method": {"const": "analyze"},
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "modelOptions", "mappingOptions", "sources"],
      "properties": {
        "backend": {"enum": ["adtof", "mock"]},
        "modelOptions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "device": {"const": "cpu"},
            "fps": {"const": 100},
            "maxThreads": {"type": "integer", "minimum": 1, "maximum": 8},
            "weightsPath": {"type": "string", "minLength": 1},
            "mockActivations": {"type": "array"},
            "thresholds": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kick": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
                "snare": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
                "tom": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
                "hihat": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
                "cymbal": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
              }
            }
          }
        },
        "mappingOptions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preToleranceMs": {"type": "number", "minimum": 0},
            "postToleranceMs": {"type": "number", "minimum": 0},
            "clusterMs": {"type": "number", "minimum": 0},
            "multiLabel": {"type": "boolean"},
            "fallbackEnabled": {"type": "boolean"},
            "fallbackNormalizedFloor": {"type": "number", "minimum": 0}
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceId", "path", "sampleRateFromLive", "lengthFramesFromLive", "regions"],
            "properties": {
              "sourceId": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "path": {"type": "string", "minLength": 1},
              "sampleRateFromLive": {"type": "integer", "minimum": 1},
              "lengthFramesFromLive": {"type": "integer", "minimum": 1},
              "regions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["regionId", "startFrame", "endFrame"],
                  "properties": {
                    "regionId": {"type": "string", "minLength": 1},
                    "startFrame": {"type": "integer", "minimum": 0},
                    "endFrame": {"type": "integer", "minimum": 1}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
