{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slice-labeler.local/schemas/analysis_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "method", "params"],
  "properties": {
    "schemaVersion": {"const": 1},
    "requestId": {"type": "string", "minLength": 1},
    "method": {"const": "analyze"},
    "params": {
      "type": "object",
      "required": ["backend", "modelOptions", "mappingOptions", "sources"],
      "properties": {
        "backend": {"enum": ["adtof", "mock"]},
        "modelOptions": {"type": "object"},
        "mappingOptions": {"type": "object"},
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sourceId", "path", "sampleRateFromLive", "regions"],
            "properties": {
              "sourceId": {"type": "string", "minLength": 1},
              "path": {"type": "string", "minLength": 1},
              "sampleRateFromLive": {"type": "integer", "minimum": 1},
              "regions": {"type": "array", "minItems": 1}
            }
          }
        }
      }
    }
  }
}
